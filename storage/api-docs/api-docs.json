{
    "openapi": "3.0.0",
    "info": {
        "title": "Partner API Platform",
        "description": "Partner integration API for external platforms. Use partner Bearer token on /api/v1/customers and /api/v1/purchase.",
        "version": "2.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Application server (paths already include /api/v1 prefix)"
        }
    ],
    "paths": {
        "/api/v1/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login with email and password",
                "operationId": "unifiedLogin",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string"
                                    },
                                    "device_name": {
                                        "type": "string",
                                        "example": "admin-api"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Token created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "data": {
                                            "properties": {
                                                "token": {
                                                    "type": "string",
                                                    "example": "1|sanctum-token-value"
                                                },
                                                "token_type": {
                                                    "type": "string",
                                                    "example": "Bearer"
                                                },
                                                "user": {
                                                    "properties": {
                                                        "id": {
                                                            "type": "integer",
                                                            "example": 1
                                                        },
                                                        "name": {
                                                            "type": "string",
                                                            "example": "Alex Admin"
                                                        },
                                                        "email": {
                                                            "type": "string",
                                                            "format": "email",
                                                            "example": "admin@local.test"
                                                        },
                                                        "role": {
                                                            "type": "string",
                                                            "example": "admin",
                                                            "nullable": true
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "error"
                                        },
                                        "error_code": {
                                            "type": "string",
                                            "example": "INVALID_CREDENTIALS"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Invalid credentials."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "423": {
                        "description": "Account locked",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "error"
                                        },
                                        "error_code": {
                                            "type": "string",
                                            "example": "ACCOUNT_LOCKED"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Account is locked. Try again later."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Revoke current Sanctum token",
                "operationId": "workspaceTokenLogout",
                "responses": {
                    "200": {
                        "description": "Token revoked",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Token revoked."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthenticated."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/customers": {
            "post": {
                "tags": [
                    "Customers"
                ],
                "summary": "Ingest customer and payment (partner Bearer token)",
                "operationId": "63608eaeb546cd420e3ce702edc186cf",
                "requestBody": {
                    "$ref": "#/components/requestBodies/PartnerSubmitCustomer"
                },
                "responses": {
                    "201": {
                        "description": "Created"
                    },
                    "404": {
                        "description": "Product not available for partner"
                    },
                    "422": {
                        "description": "Validation failed"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/purchase": {
            "post": {
                "tags": [
                    "Customers"
                ],
                "summary": "Record partner purchase",
                "description": "Partner purchase endpoint for Swap Circle and other partners.",
                "operationId": "partnerPurchase",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "partner_id",
                                    "product_id",
                                    "customer",
                                    "payment"
                                ],
                                "properties": {
                                    "partner_id": {
                                        "type": "string",
                                        "example": "SWAP_CIRCLE"
                                    },
                                    "product_id": {
                                        "type": "string",
                                        "example": "NIGERIA_BENEFICIARY_COMMUNITY"
                                    },
                                    "customer": {
                                        "type": "object"
                                    },
                                    "payment": {
                                        "type": "object"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Purchase recorded"
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "requestBodies": {
            "PartnerSubmitCustomer": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "required": [
                                "product_id",
                                "customer_data",
                                "payment"
                            ],
                            "properties": {
                                "partner_id": {
                                    "description": "Partner code. Must match authenticated partner token.",
                                    "type": "string",
                                    "example": "SWAP_CIRCLE"
                                },
                                "product_id": {
                                    "description": "Product code enabled for this partner",
                                    "type": "string",
                                    "example": "NIGERIA_BENEFICIARY_COMMUNITY"
                                },
                                "customer_data": {
                                    "description": "Beneficiary fields required by the product template.",
                                    "required": [
                                        "beneficiary_first_name",
                                        "beneficiary_surname",
                                        "beneficiary_date_of_birth",
                                        "beneficiary_gender",
                                        "beneficiary_address",
                                        "cover_start_date",
                                        "cover_duration"
                                    ],
                                    "properties": {
                                        "beneficiary_first_name": {
                                            "type": "string",
                                            "example": "Amina"
                                        },
                                        "beneficiary_surname": {
                                            "type": "string",
                                            "example": "Okafor"
                                        },
                                        "beneficiary_date_of_birth": {
                                            "type": "string",
                                            "example": "1994-04-15"
                                        },
                                        "beneficiary_gender": {
                                            "type": "string",
                                            "example": "female"
                                        },
                                        "beneficiary_address": {
                                            "type": "string",
                                            "example": "Lekki, Lagos"
                                        },
                                        "cover_start_date": {
                                            "type": "string",
                                            "example": "2026-05-01"
                                        },
                                        "cover_duration": {
                                            "type": "string",
                                            "example": "monthly"
                                        }
                                    },
                                    "type": "object"
                                },
                                "payment": {
                                    "required": [
                                        "amount",
                                        "currency",
                                        "paid_at"
                                    ],
                                    "properties": {
                                        "amount": {
                                            "type": "number",
                                            "format": "float"
                                        },
                                        "currency": {
                                            "type": "string",
                                            "example": "USD"
                                        },
                                        "paid_at": {
                                            "description": "ISO-8601 datetime, e.g. 2026-04-17T12:30:00Z",
                                            "type": "string"
                                        },
                                        "transaction_reference": {
                                            "type": "string",
                                            "nullable": true
                                        },
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "metadata": {
                                            "type": "object",
                                            "nullable": true
                                        }
                                    },
                                    "type": "object"
                                }
                            },
                            "type": "object"
                        }
                    }
                }
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Send header: Authorization: Bearer {token}",
                "bearerFormat": "Sanctum token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Admin login and logout for portal access"
        },
        {
            "name": "Customers",
            "description": "Partner ingestion APIs for customer and purchase sync"
        }
    ]
}