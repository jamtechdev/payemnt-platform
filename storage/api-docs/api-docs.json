{
    "openapi": "3.0.0",
    "info": {
        "title": "Partner API Platform",
        "description": "Admin API for product management.",
        "version": "2.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Application server (paths already include /api/v1 prefix)"
        }
    ],
    "paths": {
        "/api/v1/customers/register": {
            "post": {
                "tags": [
                    "Customer"
                ],
                "summary": "Create user then customer (partner_id auto-set from API key)",
                "operationId": "partnerCustomerStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "first_name",
                                    "last_name",
                                    "email",
                                    "password",
                                    "status"
                                ],
                                "properties": {
                                    "company_name": {
                                        "type": "string",
                                        "example": "Acme Corp"
                                    },
                                    "first_name": {
                                        "type": "string",
                                        "example": "John"
                                    },
                                    "last_name": {
                                        "type": "string",
                                        "example": "Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "secret123"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "+923001234567"
                                    },
                                    "location": {
                                        "type": "string",
                                        "example": "Karachi"
                                    },
                                    "valid_document": {
                                        "type": "string",
                                        "example": "CNIC-12345"
                                    },
                                    "id_front_image": {
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "id_back_image": {
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "profile_pic": {
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "Pending",
                                            "Active",
                                            "Inactive",
                                            "Deleted"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User and Customer created"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/customers/{uuid}": {
            "post": {
                "tags": [
                    "Customer"
                ],
                "summary": "Update customer (use POST with _method=PUT for file upload)",
                "operationId": "partnerCustomerUpdate",
                "parameters": [
                    {
                        "name": "uuid",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "properties": {
                                    "_method": {
                                        "type": "string",
                                        "default": "PUT"
                                    },
                                    "company_name": {
                                        "type": "string"
                                    },
                                    "first_name": {
                                        "type": "string"
                                    },
                                    "last_name": {
                                        "type": "string"
                                    },
                                    "phone": {
                                        "type": "string"
                                    },
                                    "location": {
                                        "type": "string"
                                    },
                                    "valid_document": {
                                        "type": "string"
                                    },
                                    "id_front_image": {
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "id_back_image": {
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "profile_pic": {
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "Pending",
                                            "Active",
                                            "Inactive",
                                            "Deleted"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated"
                    },
                    "404": {
                        "description": "Not found"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/partner/products": {
            "post": {
                "tags": [
                    "Products"
                ],
                "summary": "Create a new product (Partner API Key)",
                "operationId": "partnerProductCreate",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "partner_id",
                                    "partner_code",
                                    "product_code",
                                    "name",
                                    "status"
                                ],
                                "properties": {
                                    "partner_id": {
                                        "description": "ID of the partner",
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "partner_code": {
                                        "description": "Partner code",
                                        "type": "string",
                                        "example": "SWAP_CIRCLE"
                                    },
                                    "product_code": {
                                        "description": "Unique product code - used for edit/update later",
                                        "type": "string",
                                        "example": "PROD_001"
                                    },
                                    "image_url": {
                                        "description": "Product image URL",
                                        "type": "string",
                                        "example": "https://example.com/image.png",
                                        "nullable": true
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "Beneficiary Community Plan"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "A community protection plan",
                                        "nullable": true
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 29.99,
                                        "nullable": true
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "active",
                                        "enum": [
                                            "active",
                                            "inactive"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Product created successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Products"
                ],
                "summary": "Delete all products linked to a partner",
                "operationId": "partnerProductsDeleteByPartner",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "partner_id"
                                ],
                                "properties": {
                                    "partner_id": {
                                        "description": "ID of the partner whose products will be deleted",
                                        "type": "integer",
                                        "example": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Products deleted successfully"
                    },
                    "404": {
                        "description": "No products found for this partner"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/partner/products/{product_code}": {
            "put": {
                "tags": [
                    "Products"
                ],
                "summary": "Update an existing product (Partner API Key)",
                "operationId": "partnerProductUpdate",
                "parameters": [
                    {
                        "name": "product_code",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "PROD_001"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "image_url": {
                                        "type": "string",
                                        "example": "https://example.com/image.png",
                                        "nullable": true
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "Updated Plan Name"
                                    },
                                    "description": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 49.99,
                                        "nullable": true
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "active",
                                        "enum": [
                                            "active",
                                            "inactive"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Product updated successfully"
                    },
                    "404": {
                        "description": "Product not found"
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "requestBodies": {
            "PartnerSubmitCustomer": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "required": [
                                "product_id",
                                "customer_data",
                                "payment"
                            ],
                            "properties": {
                                "partner_id": {
                                    "description": "Partner code. Must match authenticated partner token.",
                                    "type": "string",
                                    "example": "SWAP_CIRCLE"
                                },
                                "product_id": {
                                    "description": "Product code enabled for this partner",
                                    "type": "string",
                                    "example": "NIGERIA_BENEFICIARY_COMMUNITY"
                                },
                                "customer_data": {
                                    "description": "Beneficiary fields required by the product template.",
                                    "required": [
                                        "beneficiary_first_name",
                                        "beneficiary_surname",
                                        "beneficiary_date_of_birth",
                                        "beneficiary_gender",
                                        "beneficiary_address",
                                        "cover_start_date",
                                        "cover_duration"
                                    ],
                                    "properties": {
                                        "beneficiary_first_name": {
                                            "type": "string",
                                            "example": "Amina"
                                        },
                                        "beneficiary_surname": {
                                            "type": "string",
                                            "example": "Okafor"
                                        },
                                        "beneficiary_date_of_birth": {
                                            "type": "string",
                                            "example": "1994-04-15"
                                        },
                                        "beneficiary_gender": {
                                            "type": "string",
                                            "example": "female"
                                        },
                                        "beneficiary_address": {
                                            "type": "string",
                                            "example": "Lekki, Lagos"
                                        },
                                        "cover_start_date": {
                                            "type": "string",
                                            "example": "2026-05-01"
                                        },
                                        "cover_duration": {
                                            "type": "string",
                                            "example": "monthly"
                                        }
                                    },
                                    "type": "object"
                                },
                                "payment": {
                                    "required": [
                                        "amount",
                                        "currency",
                                        "paid_at"
                                    ],
                                    "properties": {
                                        "amount": {
                                            "type": "number",
                                            "format": "float"
                                        },
                                        "currency": {
                                            "type": "string",
                                            "example": "USD"
                                        },
                                        "paid_at": {
                                            "description": "ISO-8601 datetime, e.g. 2026-04-17T12:30:00Z",
                                            "type": "string"
                                        },
                                        "transaction_reference": {
                                            "type": "string",
                                            "nullable": true
                                        },
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "metadata": {
                                            "type": "object",
                                            "nullable": true
                                        }
                                    },
                                    "type": "object"
                                }
                            },
                            "type": "object"
                        }
                    }
                }
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Send header: Authorization: Bearer {token}",
                "bearerFormat": "Sanctum token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Products",
            "description": "Product management APIs"
        },
        {
            "name": "Customer",
            "description": "Customer"
        }
    ]
}