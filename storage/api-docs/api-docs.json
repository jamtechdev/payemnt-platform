{
    "openapi": "3.0.0",
    "info": {
        "title": "InsurTech Partner Distribution API",
        "description": "Partner product distribution, customer/kyc submission, transaction and webhook APIs.",
        "version": "3.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Application server (paths already include /api/v1 prefix)"
        }
    ],
    "paths": {
        "/api/v1/partner/products": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "Get all products of authenticated partner (used by Swap Circle to pull products)",
                "operationId": "partnerProductsList",
                "responses": {
                    "200": {
                        "description": "Products list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "product_code": {
                                                        "type": "string",
                                                        "example": "NIGERIA_BENEFICIARY_COMMUNITY"
                                                    },
                                                    "name": {
                                                        "type": "string",
                                                        "example": "Beneficiary Community Plan"
                                                    },
                                                    "description": {
                                                        "type": "string",
                                                        "example": "A community protection plan"
                                                    },
                                                    "price": {
                                                        "type": "number",
                                                        "example": 739
                                                    },
                                                    "status": {
                                                        "type": "string",
                                                        "example": "active"
                                                    },
                                                    "image_url": {
                                                        "type": "string",
                                                        "example": "https://example.com/image.png"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/transactions": {
            "post": {
                "tags": [
                    "Transactions"
                ],
                "summary": "Create or update a transaction (partner auto-set from API key)",
                "operationId": "transactionStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "transaction_number",
                                    "customer_email",
                                    "product_code",
                                    "payment_status",
                                    "date_added"
                                ],
                                "properties": {
                                    "transaction_number": {
                                        "type": "string",
                                        "example": "TXN123"
                                    },
                                    "customer_email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "product_code": {
                                        "type": "string",
                                        "example": "PROD_001"
                                    },
                                    "product_type": {
                                        "type": "string",
                                        "example": "A"
                                    },
                                    "cover_duration": {
                                        "type": "string",
                                        "example": "Monthly"
                                    },
                                    "cover_start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-01-01"
                                    },
                                    "cover_end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-12-31"
                                    },
                                    "payment_status": {
                                        "type": "string",
                                        "example": "Successful"
                                    },
                                    "payment_message": {
                                        "type": "string",
                                        "example": "Payment done"
                                    },
                                    "stripe_payment_intent": {
                                        "type": "string",
                                        "example": "pi_xxx"
                                    },
                                    "stripe_payment_status": {
                                        "type": "string",
                                        "example": "succeeded"
                                    },
                                    "amount": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 20000,
                                        "nullable": true
                                    },
                                    "currency": {
                                        "type": "string",
                                        "example": "NGN",
                                        "nullable": true
                                    },
                                    "date_added": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2024-01-01 10:00:00"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Transaction created or updated"
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "404": {
                        "description": "Customer or Product not found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Transactions"
                ],
                "summary": "Permanently delete all transactions of authenticated partner",
                "operationId": "transactionDestroy",
                "responses": {
                    "200": {
                        "description": "Transactions deleted"
                    },
                    "404": {
                        "description": "No transactions found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "requestBodies": {
            "PartnerSubmitCustomer": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "required": [
                                "product_id",
                                "customer_data",
                                "payment"
                            ],
                            "properties": {
                                "partner_id": {
                                    "description": "Partner code. Must match authenticated partner token.",
                                    "type": "string",
                                    "example": "SWAP_CIRCLE"
                                },
                                "product_id": {
                                    "description": "Product code enabled for this partner",
                                    "type": "string",
                                    "example": "NIGERIA_BENEFICIARY_COMMUNITY"
                                },
                                "customer_data": {
                                    "description": "Beneficiary fields required by the product template.",
                                    "required": [
                                        "beneficiary_first_name",
                                        "beneficiary_surname",
                                        "beneficiary_date_of_birth",
                                        "beneficiary_gender",
                                        "beneficiary_address",
                                        "cover_start_date",
                                        "cover_duration"
                                    ],
                                    "properties": {
                                        "beneficiary_first_name": {
                                            "type": "string",
                                            "example": "Amina"
                                        },
                                        "beneficiary_surname": {
                                            "type": "string",
                                            "example": "Okafor"
                                        },
                                        "beneficiary_date_of_birth": {
                                            "type": "string",
                                            "example": "1994-04-15"
                                        },
                                        "beneficiary_gender": {
                                            "type": "string",
                                            "example": "female"
                                        },
                                        "beneficiary_address": {
                                            "type": "string",
                                            "example": "Lekki, Lagos"
                                        },
                                        "cover_start_date": {
                                            "type": "string",
                                            "example": "2026-05-01"
                                        },
                                        "cover_duration": {
                                            "type": "string",
                                            "example": "monthly"
                                        }
                                    },
                                    "type": "object"
                                },
                                "payment": {
                                    "required": [
                                        "amount",
                                        "currency",
                                        "paid_at"
                                    ],
                                    "properties": {
                                        "amount": {
                                            "type": "number",
                                            "format": "float"
                                        },
                                        "currency": {
                                            "type": "string",
                                            "example": "USD"
                                        },
                                        "paid_at": {
                                            "description": "ISO-8601 datetime, e.g. 2026-04-17T12:30:00Z",
                                            "type": "string"
                                        },
                                        "transaction_reference": {
                                            "type": "string",
                                            "nullable": true
                                        },
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "metadata": {
                                            "type": "object",
                                            "nullable": true
                                        }
                                    },
                                    "type": "object"
                                }
                            },
                            "type": "object"
                        }
                    }
                }
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Send header: Authorization: Bearer {token}",
                "bearerFormat": "Sanctum token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Products",
            "description": "Product sync APIs"
        },
        {
            "name": "Transactions",
            "description": "Transaction sync APIs"
        }
    ]
}