{
    "openapi": "3.0.0",
    "info": {
        "title": "Partner API Platform",
        "description": "Admin API for product management.",
        "version": "2.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Application server (paths already include /api/v1 prefix)"
        }
    ],
    "paths": {
        "/api/v1/customers/register": {
            "post": {
                "tags": [
                    "Customer"
                ],
                "summary": "Create or update customer by email (partner_id auto-set from API key)",
                "operationId": "partnerCustomerStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "first_name",
                                    "last_name",
                                    "email",
                                    "password",
                                    "status"
                                ],
                                "properties": {
                                    "company_name": {
                                        "type": "string",
                                        "example": "Acme Corp"
                                    },
                                    "first_name": {
                                        "type": "string",
                                        "example": "John"
                                    },
                                    "last_name": {
                                        "type": "string",
                                        "example": "Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "secret123"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "+923001234567"
                                    },
                                    "location": {
                                        "type": "string",
                                        "example": "Karachi"
                                    },
                                    "valid_document": {
                                        "type": "string",
                                        "example": "CNIC-12345"
                                    },
                                    "id_front_image": {
                                        "type": "string",
                                        "example": "https://example.com/id_front.jpg"
                                    },
                                    "id_back_image": {
                                        "type": "string",
                                        "example": "https://example.com/id_back.jpg"
                                    },
                                    "profile_pic": {
                                        "type": "string",
                                        "example": "https://example.com/profile.jpg"
                                    },
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "Pending",
                                            "Active",
                                            "Inactive",
                                            "Deleted"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Customer created or updated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/customers": {
            "delete": {
                "tags": [
                    "Customer"
                ],
                "summary": "Permanently delete all customers of authenticated partner",
                "operationId": "partnerCustomerDestroy",
                "responses": {
                    "200": {
                        "description": "Customers permanently deleted"
                    },
                    "404": {
                        "description": "No customers found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/occupations": {
            "post": {
                "tags": [
                    "Occupations"
                ],
                "summary": "Create or update an occupation (partner auto-set from API key)",
                "operationId": "occupationStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Engineer"
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "Active"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Occupation created or updated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Occupations"
                ],
                "summary": "Delete all occupations of authenticated partner",
                "operationId": "occupationDestroy",
                "responses": {
                    "200": {
                        "description": "Occupations deleted"
                    },
                    "404": {
                        "description": "No occupations found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/relationships": {
            "post": {
                "tags": [
                    "Relationships"
                ],
                "summary": "Create or update a relationship (partner auto-set from API key)",
                "operationId": "relationshipStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Spouse"
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "Active"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Relationship created or updated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Relationships"
                ],
                "summary": "Delete all relationships of authenticated partner",
                "operationId": "relationshipDestroy",
                "responses": {
                    "200": {
                        "description": "Relationships deleted"
                    },
                    "404": {
                        "description": "No relationships found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/task-types": {
            "post": {
                "tags": [
                    "Task Types"
                ],
                "summary": "Create or update a task type (partner auto-set from API key)",
                "operationId": "taskTypeStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Follow Up"
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "Active"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Task type created or updated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Task Types"
                ],
                "summary": "Delete all task types of authenticated partner",
                "operationId": "taskTypeDestroy",
                "responses": {
                    "200": {
                        "description": "Task types deleted"
                    },
                    "404": {
                        "description": "No task types found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/partner/products": {
            "post": {
                "tags": [
                    "Products"
                ],
                "summary": "Create or update a product (partner auto-set from API key)",
                "operationId": "partnerProductCreate",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "product_code",
                                    "name",
                                    "status"
                                ],
                                "properties": {
                                    "product_code": {
                                        "description": "Unique product code",
                                        "type": "string",
                                        "example": "PROD_001"
                                    },
                                    "image_url": {
                                        "type": "string",
                                        "example": "https://example.com/image.png",
                                        "nullable": true
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "Beneficiary Community Plan"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "A community protection plan",
                                        "nullable": true
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 29.99,
                                        "nullable": true
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "active",
                                        "enum": [
                                            "active",
                                            "inactive"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Product created or updated"
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Products"
                ],
                "summary": "Delete all products of authenticated partner",
                "operationId": "partnerProductsDeleteByPartner",
                "responses": {
                    "200": {
                        "description": "Products deleted successfully"
                    },
                    "404": {
                        "description": "No products found"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/swap-offers": {
            "post": {
                "tags": [
                    "Swap Offers"
                ],
                "summary": "Create or update a swap offer (partner auto-set from API key)",
                "operationId": "swapOfferStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "customer_email",
                                    "from_currency_code",
                                    "to_currency_code",
                                    "from_amount",
                                    "to_amount",
                                    "exchange_rate",
                                    "base_amount",
                                    "status",
                                    "date_added"
                                ],
                                "properties": {
                                    "customer_email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "from_currency_code": {
                                        "type": "string",
                                        "example": "NGN"
                                    },
                                    "to_currency_code": {
                                        "type": "string",
                                        "example": "GHS"
                                    },
                                    "from_amount": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 5000
                                    },
                                    "to_amount": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 10.5
                                    },
                                    "admin_share": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 2.5
                                    },
                                    "admin_share_amount": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 125
                                    },
                                    "exchange_rate": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 0.0021
                                    },
                                    "base_amount": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 5000
                                    },
                                    "expiry_date_time": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2024-12-31 23:59:59"
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "Pending"
                                    },
                                    "date_added": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2024-01-01 10:00:00"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Swap offer created or updated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Swap Offers"
                ],
                "summary": "Permanently delete all swap offers of authenticated partner",
                "operationId": "swapOfferDestroy",
                "responses": {
                    "200": {
                        "description": "Swap offers deleted"
                    },
                    "404": {
                        "description": "No swap offers found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/transactions": {
            "post": {
                "tags": [
                    "Transactions"
                ],
                "summary": "Create or update a transaction (partner auto-set from API key)",
                "operationId": "transactionStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "transaction_number",
                                    "customer_email",
                                    "product_code",
                                    "payment_status",
                                    "date_added"
                                ],
                                "properties": {
                                    "transaction_number": {
                                        "type": "string",
                                        "example": "TXN123"
                                    },
                                    "customer_email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "product_code": {
                                        "type": "string",
                                        "example": "PROD_001"
                                    },
                                    "product_type": {
                                        "type": "string",
                                        "example": "A"
                                    },
                                    "cover_duration": {
                                        "type": "string",
                                        "example": "Monthly"
                                    },
                                    "cover_start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-01-01"
                                    },
                                    "cover_end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-12-31"
                                    },
                                    "payment_status": {
                                        "type": "string",
                                        "example": "Successful"
                                    },
                                    "payment_message": {
                                        "type": "string",
                                        "example": "Payment done"
                                    },
                                    "stripe_payment_intent": {
                                        "type": "string",
                                        "example": "pi_xxx"
                                    },
                                    "stripe_payment_status": {
                                        "type": "string",
                                        "example": "succeeded"
                                    },
                                    "date_added": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2024-01-01 10:00:00"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Transaction created or updated"
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "404": {
                        "description": "Customer or Product not found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Transactions"
                ],
                "summary": "Permanently delete all transactions of authenticated partner",
                "operationId": "transactionDestroy",
                "responses": {
                    "200": {
                        "description": "Transactions deleted"
                    },
                    "404": {
                        "description": "No transactions found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/verify": {
            "post": {
                "tags": [
                    "Connect"
                ],
                "summary": "Connect and verify an external partner platform",
                "operationId": "partnerVerify",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "partner_code",
                                    "api_key",
                                    "base_url"
                                ],
                                "properties": {
                                    "partner_code": {
                                        "type": "string",
                                        "example": "SWAP_CIRCLE"
                                    },
                                    "api_key": {
                                        "type": "string",
                                        "example": "your-api-key-here"
                                    },
                                    "base_url": {
                                        "type": "string",
                                        "format": "uri",
                                        "example": "https://app.swapcircle.com"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Partner verified and connected successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Partner connected successfully."
                                        },
                                        "partner_name": {
                                            "type": "string",
                                            "example": "SwapCircle"
                                        },
                                        "connected_at": {
                                            "type": "string",
                                            "format": "date-time",
                                            "example": "2024-01-01T10:00:00Z"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Partner not found"
                    },
                    "401": {
                        "description": "Invalid API key or partner inactive"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        }
    },
    "components": {
        "requestBodies": {
            "PartnerSubmitCustomer": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "required": [
                                "product_id",
                                "customer_data",
                                "payment"
                            ],
                            "properties": {
                                "partner_id": {
                                    "description": "Partner code. Must match authenticated partner token.",
                                    "type": "string",
                                    "example": "SWAP_CIRCLE"
                                },
                                "product_id": {
                                    "description": "Product code enabled for this partner",
                                    "type": "string",
                                    "example": "NIGERIA_BENEFICIARY_COMMUNITY"
                                },
                                "customer_data": {
                                    "description": "Beneficiary fields required by the product template.",
                                    "required": [
                                        "beneficiary_first_name",
                                        "beneficiary_surname",
                                        "beneficiary_date_of_birth",
                                        "beneficiary_gender",
                                        "beneficiary_address",
                                        "cover_start_date",
                                        "cover_duration"
                                    ],
                                    "properties": {
                                        "beneficiary_first_name": {
                                            "type": "string",
                                            "example": "Amina"
                                        },
                                        "beneficiary_surname": {
                                            "type": "string",
                                            "example": "Okafor"
                                        },
                                        "beneficiary_date_of_birth": {
                                            "type": "string",
                                            "example": "1994-04-15"
                                        },
                                        "beneficiary_gender": {
                                            "type": "string",
                                            "example": "female"
                                        },
                                        "beneficiary_address": {
                                            "type": "string",
                                            "example": "Lekki, Lagos"
                                        },
                                        "cover_start_date": {
                                            "type": "string",
                                            "example": "2026-05-01"
                                        },
                                        "cover_duration": {
                                            "type": "string",
                                            "example": "monthly"
                                        }
                                    },
                                    "type": "object"
                                },
                                "payment": {
                                    "required": [
                                        "amount",
                                        "currency",
                                        "paid_at"
                                    ],
                                    "properties": {
                                        "amount": {
                                            "type": "number",
                                            "format": "float"
                                        },
                                        "currency": {
                                            "type": "string",
                                            "example": "USD"
                                        },
                                        "paid_at": {
                                            "description": "ISO-8601 datetime, e.g. 2026-04-17T12:30:00Z",
                                            "type": "string"
                                        },
                                        "transaction_reference": {
                                            "type": "string",
                                            "nullable": true
                                        },
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "metadata": {
                                            "type": "object",
                                            "nullable": true
                                        }
                                    },
                                    "type": "object"
                                }
                            },
                            "type": "object"
                        }
                    }
                }
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Send header: Authorization: Bearer {token}",
                "bearerFormat": "Sanctum token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Products",
            "description": "Product management APIs"
        },
        {
            "name": "Customer",
            "description": "Customer registration & management"
        },
        {
            "name": "Transactions",
            "description": "Transaction APIs"
        },
        {
            "name": "Swap Offers",
            "description": "Swap offer APIs"
        },
        {
            "name": "Occupations",
            "description": "Occupation lookup APIs"
        },
        {
            "name": "Relationships",
            "description": "Relationship lookup APIs"
        },
        {
            "name": "Task Types",
            "description": "Task type lookup APIs"
        },
        {
            "name": "Connect",
            "description": "Connect"
        }
    ]
}